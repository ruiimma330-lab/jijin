# ===== 数据源配置 =====
# akshare 免费，无需 API Key，开箱即用

# tushare (可选，免费注册获取 token: https://tushare.pro)
TUSHARE_TOKEN=your_token_here

# ===== 专业数据源 (按需配置) =====
# Wind 终端接口
# WIND_USERNAME=
# WIND_PASSWORD=

# Choice 东方财富
# CHOICE_TOKEN=

# ===== AI 投资顾问 (OpenAI 兼容接口) =====
# 支持 DeepSeek, Qwen, Moonshot 等国内模型
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
